def clean_text(text):
    text = str(text).lower()
    text = re.sub(r"http\S+", " ", text)
    text = re.sub(r"[^a-z\s]", " ", text)
    return text.strip()

df['clean_text'] = df['clean_text'].apply(clean_text)
